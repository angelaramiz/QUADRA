# 🔒 Archivo de ejemplo para variables de entorno - QUADRA
# ⚠️  NUNCA subas el archivo .env real al repositorio
# 
# Instrucciones:
# 1. Copia este archivo como .env en la carpeta app/
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. El archivo .env debe estar en .gitignore

# ===========================================
# 🚀 CONFIGURACIÓN DE FLASK
# ===========================================
SECRET_KEY=your_secret_key_here_generate_a_new_one
FLASK_ENV=development
FLASK_DEBUG=True

# ===========================================
# 🗄️ BASE DE DATOS
# ===========================================
# Para desarrollo local (SQLite):
# DATABASE_URL=sqlite:///instance/quadra.db

# Para producción (Supabase PostgreSQL):
# DATABASE_URL=postgresql://username:password@host:port/database

# ===========================================
# 🗺️ CONFIGURACIÓN DE MAPAS
# ===========================================
MAP_DEFAULT_LAT=19.4326
MAP_DEFAULT_LNG=-99.1332
MAP_DEFAULT_ZOOM=12

# ===========================================
# 📁 CONFIGURACIÓN DE ARCHIVOS
# ===========================================
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216

# ===========================================
# 🔐 CONFIGURACIÓN DE SEGURIDAD
# ===========================================
WTF_CSRF_TIME_LIMIT=3600
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SECURE=False
PERMANENT_SESSION_LIFETIME=86400
