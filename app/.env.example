# Configuración de Seguridad para Quadra

# Variables de entorno (copia este archivo como .env y modifica los valores)
SECRET_KEY=genera_una_clave_secreta_super_larga_y_aleatoria_aqui
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/quadra_db
FLASK_ENV=development
FLASK_DEBUG=True

# Para producción:
# FLASK_ENV=production
# FLASK_DEBUG=False
# DATABASE_URL=postgresql://usuario:contraseña@servidor:5432/quadra_db

# Configuración adicional de seguridad
# WTF_CSRF_TIME_LIMIT=3600  # Token CSRF válido por 1 hora
# SESSION_COOKIE_SECURE=True  # Solo HTTPS en producción
# SESSION_COOKIE_HTTPONLY=True  # No accesible desde JavaScript
# PERMANENT_SESSION_LIFETIME=86400  # Sesión válida por 24 horas
